{
    "version": 2,
    "builds": [
        {
            "src": "Backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "Frontend/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "Backend/main.py"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}